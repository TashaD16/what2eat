{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "preview":  { "dependsOn": ["build"] },
    "lint":     { "dependsOn": ["^build"] },
    "format":   { "cache": false },
    "test:e2e": { "dependsOn": ["^build"], "cache": false }
  }
}
